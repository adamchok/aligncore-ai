# Server
PORT=4000

# CORS — browser origin for aligncore-fe (omit in dev to allow all)
FE_ORIGIN=http://localhost:3001

# Firebase Admin SDK — recommended
# 1. Create folder: aligncore-be/credentials/  (gitignored)
# 2. Download service account JSON from Firebase Console → Project settings → Service accounts
# 3. Save as: aligncore-be/credentials/firebase-service-account.json
# 4. Point here (relative to aligncore-be when you run pnpm dev / pnpm seed from that directory)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/firebase-service-account.json
# 5. Firebase Console → Firestore Database → Create database once (otherwise pnpm seed may fail with grpc NOT_FOUND)
# If you created a non-default database, set its ID here (shown in Firestore console). Omit or use (default) for the primary DB.
FIRESTORE_DATABASE_ID=aligncore-db

# Fallback if you don’t use GOOGLE_APPLICATION_CREDENTIALS (inline PEM — easy to break on Windows)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Gemini — pick ONE mode:
#
# ── RECOMMENDED FOR DEVELOPMENT ─────────────────────────────────────────────
# B) Gemini Developer API (Google AI Studio)
#    - Get a free API key at https://aistudio.google.com/app/apikey
#    - Quota: 1,500 RPM for embeddings (vs ~5 RPM default on Vertex AI)
#    - No GCP project / service account needed
#    - NOTE: Files API (PDF upload) is also supported in this mode
GEMINI_USE_VERTEX=false
GEMINI_API_KEY=your-gemini-api-key
#
# ── FOR PRODUCTION / GCP DEPLOYMENT ─────────────────────────────────────────
# A) Vertex AI (uses GOOGLE_APPLICATION_CREDENTIALS service account)
#    - Enable "Vertex AI API" on your GCP project
#    - Grant service account role: "Vertex AI User" (roles/aiplatform.user)
#    - Default embedding quota is ~5 RPM — request increase at:
#      GCP Console → IAM & Admin → Quotas → filter "textembedding-gecko"
#    - Billing credits do NOT increase quotas (quotas are rate limits, not cost limits)
# GEMINI_USE_VERTEX=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# AI Provider — pick ONE:
#
# ── Gemini (default) ─────────────────────────────────────────────────────────
# Uses GEMINI_API_KEY (Developer) or Vertex AI credentials above.
# AI_PROVIDER=gemini   ← default, no need to set explicitly
#
# ── Anthropic Claude ─────────────────────────────────────────────────────────
# Much higher RPM limits — recommended if you hit Gemini quota errors.
# embedText() always uses Gemini (Anthropic has no embedding API).
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   ← default (fast + cheap)
# ANTHROPIC_MODEL=claude-sonnet-4-6           ← smarter, use for onboarding chat

# WAHA (WhatsApp HTTP API)
WAHA_URL=http://localhost:3000
WAHA_SESSION=default
WAHA_API_KEY=your-waha-api-key
WAHA_WEBHOOK_SECRET=your-webhook-secret

# Demo
DEMO_RE_ID=demo-re-001
