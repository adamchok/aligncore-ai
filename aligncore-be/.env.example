# Server
PORT=4000

# CORS — browser origin for aligncore-fe (omit in dev to allow all)
FE_ORIGIN=http://localhost:3001

# Firebase Admin SDK — recommended
# 1. Create folder: aligncore-be/credentials/  (gitignored)
# 2. Download service account JSON from Firebase Console → Project settings → Service accounts
# 3. Save as: aligncore-be/credentials/firebase-service-account.json
# 4. Point here (relative to aligncore-be when you run pnpm dev / pnpm seed from that directory)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/firebase-service-account.json
# 5. Firebase Console → Firestore Database → Create database once (otherwise pnpm seed may fail with grpc NOT_FOUND)
FIRESTORE_DATABASE_ID=aligncore-db

# Fallback inline credentials (less recommended — easy to break on Windows with multiline PEM)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# ── AI Model ──────────────────────────────────────────────────────────────────
# All AI agents use Google ADK with Gemini. Pick the model below.
# The same model is used for matching, onboarding, summarization, and extraction.
AI_MODEL=gemini-2.5-flash
# AI_MODEL=gemini-2.0-pro         ← smarter, higher cost
# AI_MODEL=gemini-2.5-pro-preview ← most capable, slower

# ── Gemini Auth — pick ONE mode ───────────────────────────────────────────────
#
# ── RECOMMENDED FOR DEVELOPMENT: Gemini Developer API (Google AI Studio) ──────
# Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_USE_VERTEX=false
GEMINI_API_KEY=your-gemini-api-key

# ── FOR PRODUCTION / GCP: Vertex AI (uses GOOGLE_APPLICATION_CREDENTIALS) ─────
# Enable "Vertex AI API" on your GCP project.
# Grant service account role: "Vertex AI User" (roles/aiplatform.user).
# GEMINI_USE_VERTEX=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ── Knowledge Base & mentor profile photos ─────────────────────────────────────
# GCS bucket used by the backend for: company/mentor knowledge files (optional GCS)
# and **mentor profile photos** (required for photo upload — no Firebase Storage rules on the FE).
# For stable image URLs without signed-url expiry, grant public read on `mentors/` and `companies/` (or use object ACL publicRead if bucket allows it).
# KNOWLEDGE_BUCKET=your-project-id.appspot.com
# WAHA (WhatsApp HTTP API)
WAHA_URL=http://localhost:3000
WAHA_SESSION=default
WAHA_API_KEY=your-waha-api-key
WAHA_WEBHOOK_SECRET=your-webhook-secret
# Phone number (digits only, no +) to receive WhatsApp alerts for unanswerable Q&A emails
WHATSAPP_OWNER_PHONE=60123456789

# ── Gmail AI Inbox ─────────────────────────────────────────────────────────────
# OAuth2 credentials — create at https://console.cloud.google.com/apis/credentials
# Enable the Gmail API and create an OAuth2 client (Desktop app type).
# Run the one-time auth flow to obtain the refresh token (see docs/gmail-oauth-setup.md).
GMAIL_CLIENT_ID=your-gmail-oauth-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-oauth-refresh-token
# The Gmail address to read and send from (must match the OAuth2 account)
GMAIL_USER_EMAIL=your-accelerator-inbox@gmail.com
# Pub/Sub topic for Gmail push notifications (full resource name)
# Format: projects/{your-gcp-project-id}/topics/{topic-name}
GMAIL_PUBSUB_TOPIC=projects/your-project-id/topics/gmail-inbox
